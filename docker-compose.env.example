# Copy to `.env` (which is gitignored). `docker compose` loads it automatically.
#
# One-time tunnel setup on the host (credentials stay under ~/.cloudflared,
# nothing secret is ever committed):
#
#   cloudflared tunnel login                              # only if not already
#   cloudflared tunnel create wos-sim                     # creates ~/.cloudflared/<UUID>.json
#   cloudflared tunnel route dns wos-sim wos-sim.ratme.org
#
# Then paste the printed UUID into TUNNEL_ID below.

# UUID of the Cloudflare Tunnel ("wos-sim"). Must match the credentials JSON
# file present at ${CLOUDFLARED_DIR}/<UUID>.json.
TUNNEL_ID=

# Public hostname routed to the tunnel. Used only for `cloudflared tunnel route
# dns` at setup time; cloudflared itself reads the DNS record at runtime.
TUNNEL_HOSTNAME=wos-sim.ratme.org

# Host directory holding cloudflared credentials. Mounted read-only into the
# sidecar. Defaults to ~/.cloudflared.
# CLOUDFLARED_DIR=~/.cloudflared

# Local host port published by the app service (the tunnel uses the internal
# docker network and does not rely on this).
APP_PORT=3000
